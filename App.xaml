<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Kakikomi.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kakikomi">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="OpBarBg" Color="#FF0F172A" />
            <SolidColorBrush x:Key="OpPageBg" Color="#FF020617" />
            <SolidColorBrush x:Key="OpPanelBorderBrush" Color="#FF334155" />
            <SolidColorBrush x:Key="OpTextBrush" Color="#FFE2E8F0" />
            <SolidColorBrush x:Key="OpMutedTextBrush" Color="#FF94A3B8" />
            <!-- 暗いバー上でもボタンが浮いて見えるよう、面だけ明るく（枠線は使わずジャギ防止） -->
            <SolidColorBrush x:Key="OpControlFillBrush" Color="#FF556A84" />
            <SolidColorBrush x:Key="OpControlForegroundBrush" Color="#FFF8FAFC" />
            <SolidColorBrush x:Key="OpControlFillDisabledBrush" Color="#FF2E3A4F" />
            <SolidColorBrush x:Key="OpControlForegroundDisabledBrush" Color="#FF94A3B8" />
            <SolidColorBrush x:Key="PenSwatchRingOuterBrush" Color="#FFF8FAFC" />
            <SolidColorBrush x:Key="PenSwatchRingInnerBrush" Color="#FF38BDF8" />

            <!-- 角丸＋1px枠はジャギりやすいので、枠なしの面だけテンプレ -->
            <ControlTemplate x:Key="OpButtonChromeTemplate" TargetType="Button">
                <Grid x:Name="RootGrid" Background="Transparent">
                    <Border
                        x:Name="BackgroundElement"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{TemplateBinding Background}"
                        BorderThickness="0"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid>
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                AutomationProperties.AccessibilityView="Raw"
                                Foreground="{TemplateBinding Foreground}" />
                            <Border
                                x:Name="HoverOverlay"
                                Background="White"
                                Opacity="0"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False" />
                        </Grid>
                    </Border>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Target="HoverOverlay.Opacity" Value="0.12" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Target="HoverOverlay.Opacity" Value="0.22" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled">
                                <VisualState.Setters>
                                    <Setter Target="RootGrid.Opacity" Value="0.5" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Grid>
            </ControlTemplate>

            <ControlTemplate x:Key="OpToggleChromeTemplate" TargetType="ToggleButton">
                <Grid x:Name="RootGrid" Background="Transparent">
                    <Border
                        x:Name="BackgroundElement"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{TemplateBinding Background}"
                        BorderThickness="0"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid>
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                AutomationProperties.AccessibilityView="Raw"
                                Foreground="{TemplateBinding Foreground}" />
                            <Border
                                x:Name="HoverOverlay"
                                Background="White"
                                Opacity="0"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                IsHitTestVisible="False" />
                        </Grid>
                    </Border>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Target="HoverOverlay.Opacity" Value="0.12" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Target="HoverOverlay.Opacity" Value="0.22" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled">
                                <VisualState.Setters>
                                    <Setter Target="RootGrid.Opacity" Value="0.5" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Checked">
                                <VisualState.Setters>
                                    <Setter Target="HoverOverlay.Opacity" Value="0.08" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="CheckedPointerOver">
                                <VisualState.Setters>
                                    <Setter Target="HoverOverlay.Opacity" Value="0.16" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="CheckedPressed">
                                <VisualState.Setters>
                                    <Setter Target="HoverOverlay.Opacity" Value="0.24" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="CheckedDisabled">
                                <VisualState.Setters>
                                    <Setter Target="RootGrid.Opacity" Value="0.5" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Indeterminate" />
                            <VisualState x:Name="IndeterminatePointerOver" />
                            <VisualState x:Name="IndeterminatePressed" />
                            <VisualState x:Name="IndeterminateDisabled" />
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Grid>
            </ControlTemplate>

            <Style
                x:Key="OpButtonStyle"
                TargetType="Button">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="MinHeight" Value="48" />
                <Setter Property="MinWidth" Value="88" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="{StaticResource OpControlFillBrush}" />
                <Setter Property="Foreground" Value="{StaticResource OpControlForegroundBrush}" />
                <Setter Property="Template" Value="{StaticResource OpButtonChromeTemplate}" />
            </Style>

            <Style
                x:Key="OpButtonCompactStyle"
                TargetType="Button"
                BasedOn="{StaticResource OpButtonStyle}">
                <Setter Property="MinWidth" Value="48" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="FontSize" Value="18" />
            </Style>

            <!-- ツールバー右端：編集・設定を縦2段に収める小さめボタン -->
            <Style
                x:Key="OpButtonSideStyle"
                TargetType="Button"
                BasedOn="{StaticResource OpButtonStyle}">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="8,2" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Width" Value="84" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style
                x:Key="OpToggleStyle"
                TargetType="ToggleButton">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="MinHeight" Value="48" />
                <Setter Property="MinWidth" Value="88" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="{StaticResource OpControlFillBrush}" />
                <Setter Property="Foreground" Value="{StaticResource OpControlForegroundBrush}" />
                <Setter Property="Template" Value="{StaticResource OpToggleChromeTemplate}" />
            </Style>

            <Style x:Key="NetaListItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="2" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid
                                x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver" />
                                        <VisualState x:Name="Disabled" />
                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="#FF0D9488" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="SelectedPointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="#FF14B8A6" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="SelectedSwiping">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="#FF0D9488" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="SelectedUnfocused">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="#FF64748B" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="DragStates">
                                        <VisualState x:Name="NotDragging" />
                                        <VisualState x:Name="Dragging">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Opacity" Value="0.55" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="DraggingTarget" />
                                        <VisualState x:Name="MultipleDraggingPrimary" />
                                        <VisualState x:Name="MultipleDraggingSecondary" />
                                        <VisualState x:Name="DraggedPlaceholder" />
                                        <VisualState x:Name="ReorderedPlaceholder">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Opacity" Value="0" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="ReorderHintStates">
                                        <VisualState x:Name="NoReorderHint" />
                                        <VisualState x:Name="BottomReorderHint">
                                            <VisualState.Setters>
                                                <Setter Target="ReorderHintBorder.BorderThickness" Value="0,0,0,3" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="TopReorderHint">
                                            <VisualState.Setters>
                                                <Setter Target="ReorderHintBorder.BorderThickness" Value="0,3,0,0" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="LeftReorderHint" />
                                        <VisualState x:Name="RightReorderHint" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Border
                                    x:Name="ReorderHintBorder"
                                    BorderBrush="#FF2DD4BF"
                                    BorderThickness="0">
                                    <ContentPresenter
                                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ペン色: 外枠なし・丸だけ。選択時は白＋黒の二重リング -->
            <Style x:Key="OpPenSwatchToggleStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Width" Value="48" />
                <Setter Property="Height" Value="48" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid Width="48" Height="48" Background="Transparent">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Target="SelectionRingOuter.Opacity" Value="0" />
                                                <Setter Target="SelectionRingInner.Opacity" Value="0" />
                                                <Setter Target="SwatchScale.ScaleX" Value="1" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="SwatchScale.ScaleX" Value="1.06" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1.06" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="SwatchScale.ScaleX" Value="0.94" />
                                                <Setter Target="SwatchScale.ScaleY" Value="0.94" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Opacity" Value="0.45" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="SelectionRingOuter.Opacity" Value="1" />
                                                <Setter Target="SelectionRingInner.Opacity" Value="1" />
                                                <Setter Target="SwatchScale.ScaleX" Value="1.12" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1.12" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="CheckedPointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="SelectionRingOuter.Opacity" Value="1" />
                                                <Setter Target="SelectionRingInner.Opacity" Value="1" />
                                                <Setter Target="SwatchScale.ScaleX" Value="1.16" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1.16" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="CheckedPressed">
                                            <VisualState.Setters>
                                                <Setter Target="SelectionRingOuter.Opacity" Value="1" />
                                                <Setter Target="SelectionRingInner.Opacity" Value="1" />
                                                <Setter Target="SwatchScale.ScaleX" Value="1.08" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1.08" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="CheckedDisabled" />
                                        <VisualState x:Name="Indeterminate" />
                                        <VisualState x:Name="IndeterminatePointerOver" />
                                        <VisualState x:Name="IndeterminatePressed" />
                                        <VisualState x:Name="IndeterminateDisabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Grid
                                    x:Name="RootGrid"
                                    RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="SwatchScale" ScaleX="1" ScaleY="1" />
                                    </Grid.RenderTransform>
                                    <Ellipse
                                        x:Name="SelectionRingOuter"
                                        Width="40"
                                        Height="40"
                                        Stroke="{StaticResource PenSwatchRingOuterBrush}"
                                        StrokeThickness="4"
                                        Opacity="0"
                                        IsHitTestVisible="False" />
                                    <Ellipse
                                        x:Name="SelectionRingInner"
                                        Width="34"
                                        Height="34"
                                        Stroke="{StaticResource PenSwatchRingInnerBrush}"
                                        StrokeThickness="2"
                                        Opacity="0"
                                        IsHitTestVisible="False" />
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
