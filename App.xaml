<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Kakikomi.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Kakikomi">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="OpBarBg" Color="#FF0F172A" />
            <SolidColorBrush x:Key="OpPageBg" Color="#FF020617" />
            <SolidColorBrush x:Key="OpPanelBorderBrush" Color="#FF334155" />
            <SolidColorBrush x:Key="OpTextBrush" Color="#FFE2E8F0" />
            <SolidColorBrush x:Key="OpMutedTextBrush" Color="#FF94A3B8" />
            <SolidColorBrush x:Key="PenSwatchRingOuterBrush" Color="#FFF8FAFC" />
            <SolidColorBrush x:Key="PenSwatchRingInnerBrush" Color="#FF38BDF8" />

            <!-- OpToggle*: システム ThemeDictionary の ToggleButton* を避け、ボタン個別 Resources で上書き可能にする -->
            <SolidColorBrush x:Key="OpToggleBackground" Color="#FFF8FAFC" />
            <SolidColorBrush x:Key="OpToggleBackgroundPointerOver" Color="#FFE2E8F0" />
            <SolidColorBrush x:Key="OpToggleBackgroundPressed" Color="#FFCBD5E1" />
            <SolidColorBrush x:Key="OpToggleBackgroundChecked" Color="#FF0D9488" />
            <SolidColorBrush x:Key="OpToggleBackgroundCheckedPointerOver" Color="#FF14B8A6" />
            <SolidColorBrush x:Key="OpToggleBackgroundCheckedPressed" Color="#FF0F766E" />
            <SolidColorBrush x:Key="OpToggleForeground" Color="#FF0F172A" />
            <SolidColorBrush x:Key="OpToggleForegroundPointerOver" Color="#FF0F172A" />
            <SolidColorBrush x:Key="OpToggleForegroundPressed" Color="#FF1E293B" />
            <SolidColorBrush x:Key="OpToggleForegroundChecked" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OpToggleForegroundCheckedPointerOver" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OpToggleForegroundCheckedPressed" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OpToggleBorderBrush" Color="#FF475569" />
            <SolidColorBrush x:Key="OpToggleBorderBrushPointerOver" Color="#FF334155" />
            <SolidColorBrush x:Key="OpToggleBorderBrushPressed" Color="#FF64748B" />
            <SolidColorBrush x:Key="OpToggleBorderBrushChecked" Color="#FF0F766E" />
            <SolidColorBrush x:Key="OpToggleBorderBrushCheckedPointerOver" Color="#FF0F766E" />
            <SolidColorBrush x:Key="OpToggleBorderBrushCheckedPressed" Color="#FF115E59" />

            <Style x:Key="FlatButtonChromeStyle" TargetType="Button">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Foreground" Value="#FF0F172A" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <!-- 色は常に TemplateBinding（ThemeResource で上書きしない） -->
                            <Border
                                x:Name="OuterRim"
                                Background="{TemplateBinding BorderBrush}"
                                Padding="2"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <Border
                                    x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="PointerOver" />
                                            <VisualState x:Name="Pressed">
                                                <VisualState.Setters>
                                                    <Setter Target="OuterRim.Padding" Value="2,3,2,1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Disabled">
                                                <VisualState.Setters>
                                                    <Setter Target="RootBorder.Opacity" Value="0.55" />
                                                    <Setter Target="OuterRim.Opacity" Value="0.55" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <ContentPresenter
                                        x:Name="ContentPresenter"
                                        Padding="{TemplateBinding Padding}"
                                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        Foreground="{TemplateBinding Foreground}" />
                                </Border>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FlatToggleButtonChromeStyle" TargetType="ToggleButton">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Foreground" Value="#FF0F172A" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <!-- 色は常に TemplateBinding。選択色は code-behind で Background を差し替える -->
                            <Border
                                x:Name="OuterRim"
                                Background="{TemplateBinding BorderBrush}"
                                Padding="2"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <Border
                                    x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="PointerOver" />
                                            <VisualState x:Name="Pressed">
                                                <VisualState.Setters>
                                                    <Setter Target="OuterRim.Padding" Value="2,3,2,1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Disabled">
                                                <VisualState.Setters>
                                                    <Setter Target="OuterRim.Opacity" Value="0.55" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="Checked" />
                                            <VisualState x:Name="CheckedPointerOver" />
                                            <VisualState x:Name="CheckedPressed">
                                                <VisualState.Setters>
                                                    <Setter Target="OuterRim.Padding" Value="2,3,2,1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="CheckedDisabled" />
                                            <VisualState x:Name="Indeterminate" />
                                            <VisualState x:Name="IndeterminatePointerOver" />
                                            <VisualState x:Name="IndeterminatePressed" />
                                            <VisualState x:Name="IndeterminateDisabled" />
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <ContentPresenter
                                        x:Name="ContentPresenter"
                                        Padding="{TemplateBinding Padding}"
                                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        Foreground="{TemplateBinding Foreground}" />
                                </Border>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style
                x:Key="OpButtonStyle"
                TargetType="Button"
                BasedOn="{StaticResource FlatButtonChromeStyle}">
                <Setter Property="Background" Value="#FFF8FAFC" />
                <Setter Property="Foreground" Value="#FF0F172A" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="Padding" Value="18,12" />
                <Setter Property="MinHeight" Value="48" />
                <Setter Property="MinWidth" Value="88" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="BorderBrush" Value="#FF475569" />
            </Style>

            <Style
                x:Key="OpToggleStyle"
                TargetType="ToggleButton"
                BasedOn="{StaticResource FlatToggleButtonChromeStyle}">
                <Setter Property="Background" Value="#FFF8FAFC" />
                <Setter Property="Foreground" Value="#FF0F172A" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="Padding" Value="18,12" />
                <Setter Property="MinHeight" Value="48" />
                <Setter Property="MinWidth" Value="88" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="BorderBrush" Value="#FF475569" />
            </Style>

            <Style x:Key="NetaListItemContainerStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="2" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid
                                x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver" />
                                        <VisualState x:Name="Disabled" />
                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="#FF0D9488" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="SelectedPointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="#FF14B8A6" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="SelectedSwiping">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="#FF0D9488" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="SelectedUnfocused">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="#FF64748B" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ペン色: 外枠なし・丸だけ。選択時は白＋黒の二重リング -->
            <Style x:Key="OpPenSwatchToggleStyle" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Width" Value="44" />
                <Setter Property="Height" Value="44" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid Width="44" Height="44" Background="Transparent">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Target="SelectionRingOuter.Opacity" Value="0" />
                                                <Setter Target="SelectionRingInner.Opacity" Value="0" />
                                                <Setter Target="SwatchScale.ScaleX" Value="1" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="SwatchScale.ScaleX" Value="1.06" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1.06" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="SwatchScale.ScaleX" Value="0.94" />
                                                <Setter Target="SwatchScale.ScaleY" Value="0.94" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Opacity" Value="0.45" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="SelectionRingOuter.Opacity" Value="1" />
                                                <Setter Target="SelectionRingInner.Opacity" Value="1" />
                                                <Setter Target="SwatchScale.ScaleX" Value="1.12" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1.12" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="CheckedPointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="SelectionRingOuter.Opacity" Value="1" />
                                                <Setter Target="SelectionRingInner.Opacity" Value="1" />
                                                <Setter Target="SwatchScale.ScaleX" Value="1.16" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1.16" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="CheckedPressed">
                                            <VisualState.Setters>
                                                <Setter Target="SelectionRingOuter.Opacity" Value="1" />
                                                <Setter Target="SelectionRingInner.Opacity" Value="1" />
                                                <Setter Target="SwatchScale.ScaleX" Value="1.08" />
                                                <Setter Target="SwatchScale.ScaleY" Value="1.08" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="CheckedDisabled" />
                                        <VisualState x:Name="Indeterminate" />
                                        <VisualState x:Name="IndeterminatePointerOver" />
                                        <VisualState x:Name="IndeterminatePressed" />
                                        <VisualState x:Name="IndeterminateDisabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Grid
                                    x:Name="RootGrid"
                                    RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="SwatchScale" ScaleX="1" ScaleY="1" />
                                    </Grid.RenderTransform>
                                    <Ellipse
                                        x:Name="SelectionRingOuter"
                                        Width="40"
                                        Height="40"
                                        Stroke="{StaticResource PenSwatchRingOuterBrush}"
                                        StrokeThickness="4"
                                        Opacity="0"
                                        IsHitTestVisible="False" />
                                    <Ellipse
                                        x:Name="SelectionRingInner"
                                        Width="34"
                                        Height="34"
                                        Stroke="{StaticResource PenSwatchRingInnerBrush}"
                                        StrokeThickness="2"
                                        Opacity="0"
                                        IsHitTestVisible="False" />
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
