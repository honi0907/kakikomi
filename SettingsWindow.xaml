<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Kakikomi.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kakikomi.Controls"
    Title="Kakikomi 設定">

    <Grid Background="#FF0F172A" RequestedTheme="Dark">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Padding="12"
            Background="#FF020617"
            BorderBrush="#FF334155"
            BorderThickness="0,0,1,0">
            <ListView
                x:Name="NavList"
                SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="12,10" />
                        <Setter Property="Margin" Value="0,0,0,4" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListViewItem Tag="Exit" Content="ソフト終了" Margin="0,0,0,20" />
                <ListViewItem Tag="Version" Content="バージョン / 更新" />
                <ListViewItem Tag="Demo" Content="DEMOモード" />
                <ListViewItem Tag="Clean" Content="クリーン出力" />
                <ListViewItem Tag="Save" Content="保存" />
                <ListViewItem Tag="Convert" Content=".mov 変換" />
                <ListViewItem Tag="NetaList" Content="ネタ一覧" />
                <ListViewItem Tag="Playback" Content="再生" />
                <ListViewItem Tag="Palette" Content="パレットの色編集" />
                <ListViewItem Tag="PenSize" Content="ペンサイズ" />
                <ListViewItem Tag="FullSize" Content="コンパネ起動サイズ" />
            </ListView>
        </Border>

        <ScrollViewer
            Grid.Column="1"
            Padding="24"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <StackPanel x:Name="PanelVersion" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="バージョン / 更新" />
                    <TextBlock
                        x:Name="VersionInfoText"
                        FontSize="16"
                        Foreground="#FFE2E8F0"
                        Text="Kakikomi v1.0.0" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="GitHub Release の Setup インストーラーを取得して更新します。開発ビルド（bin）からは適用できません。" />
                    <Button
                        x:Name="OnlineUpdateBtn"
                        MinWidth="220"
                        MinHeight="44"
                        Content="オンライン更新を確認" />
                    <TextBlock
                        x:Name="UpdateStatusText"
                        Foreground="#FF94A3B8"
                        FontSize="13"
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="#FFF8FAFC"
                        Text="更新履歴" />
                    <TextBlock
                        x:Name="ReleaseNotesStatusText"
                        Foreground="#FF94A3B8"
                        FontSize="13"
                        TextWrapping="Wrap"
                        Text="GitHub から読み込み中..." />
                    <ItemsControl x:Name="ReleaseNotesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,12"
                                    Padding="14"
                                    Background="#FF020617"
                                    BorderBrush="#FF334155"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="#FFF8FAFC"
                                            Text="{Binding Title}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="#FF94A3B8"
                                            Text="{Binding PublishedLabel}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#FFE2E8F0"
                                            LineHeight="20"
                                            Text="{Binding Body}"
                                            TextWrapping="Wrap"
                                            IsTextSelectionEnabled="True" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel x:Name="PanelDemo" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="DEMOモード" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="ON のとき、コンパネとクリーン出力に「DEMO」ウォーターマークを表示します。既定は ON です。" />
                    <TextBlock
                        x:Name="DemoStatusText"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFFBBF24"
                        Text="状態: ON" />
                    <StackPanel x:Name="DemoUnlockPanel" Spacing="12">
                        <PasswordBox
                            x:Name="DemoPasswordBox"
                            Header="解除パスワード"
                            PlaceholderText="パスワードを入力" />
                        <TextBlock
                            x:Name="DemoUnlockErrorText"
                            Foreground="#FFF87171"
                            TextWrapping="Wrap"
                            Visibility="Collapsed" />
                        <Button
                            x:Name="DemoUnlockBtn"
                            MinWidth="180"
                            MinHeight="44"
                            Content="DEMOを解除" />
                    </StackPanel>
                    <Button
                        x:Name="DemoEnableBtn"
                        MinWidth="220"
                        MinHeight="44"
                        Content="DEMOモードを再度ONにする"
                        Visibility="Collapsed" />
                </StackPanel>

                <StackPanel x:Name="PanelClean" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="クリーン出力" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="拡張ディスプレイ（セカンダリ）へクリーン映像を出力します。セカンダリ接続時は自動でも起動します。" />
                    <Button
                        x:Name="OpenCleanBtn"
                        MinWidth="180"
                        MinHeight="44"
                        Content="クリーン出力を開く" />
                </StackPanel>

                <StackPanel x:Name="PanelSave" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="保存" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="ペンで描き込んでから 1 秒後に、その時点の映像フレーム＋書き込みを PNG（1920×1080）として自動保存します。再生開始時は書き込みが消え、待ち中の保存は先に実行されます。ポータブル版は exe 隣の save、インストール版は LocalAppData\Kakikomi\save に保存します。" />
                    <TextBlock
                        x:Name="SaveFolderPathText"
                        FontFamily="Consolas"
                        FontSize="13"
                        Foreground="#FFE2E8F0"
                        IsTextSelectionEnabled="True"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="OpenSaveFolderBtn"
                        MinWidth="220"
                        MinHeight="44"
                        Content="save フォルダを開く" />
                </StackPanel>

                <StackPanel x:Name="PanelConvert" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text=".mov 変換" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text=".mov を検出したとき、再生用の H.264 mp4 へ変換します。元の .mov は削除せずそのまま残します。変換先はこのフォルダです。" />
                    <TextBlock
                        x:Name="ConvertFolderPathText"
                        FontFamily="Consolas"
                        FontSize="13"
                        Foreground="#FFE2E8F0"
                        IsTextSelectionEnabled="True"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="OpenConvertFolderBtn"
                        MinWidth="220"
                        MinHeight="44"
                        Content="変換先フォルダを開く" />
                </StackPanel>

                <StackPanel x:Name="PanelNetaList" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="ネタ一覧" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="操作画面と同じ一覧です。チェックして複数消去、または一斉消去できます。PC上の動画ファイルは削除されません。" />
                    <TextBlock
                        x:Name="NetaListCountText"
                        Foreground="#FFE2E8F0"
                        Text="0 本" />
                    <ListView
                        x:Name="NetaManageList"
                        MinHeight="280"
                        MaxHeight="360"
                        SelectionMode="Multiple"
                        IsMultiSelectCheckBoxEnabled="True">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Foreground="#FFE2E8F0"
                                    FontSize="14"
                                    Text="{Binding DisplayName}"
                                    TextWrapping="NoWrap"
                                    TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Spacing="10" Orientation="Horizontal">
                        <Button
                            x:Name="RemoveSelectedNetaBtn"
                            MinWidth="180"
                            MinHeight="44"
                            Content="選択を消去" />
                        <Button
                            x:Name="RemoveAllNetaBtn"
                            MinWidth="180"
                            MinHeight="44"
                            Content="一斉消去" />
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="PanelPlayback" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="再生" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="レジューム再生を ON にすると、別ネタを見て戻ったときに、前回止めた位置から続き再生します。OFF（既定）では戻るたびに先頭から始まります。" />
                    <CheckBox
                        x:Name="ResumePlaybackCheck"
                        Content="レジューム再生"
                        Foreground="#FFE2E8F0" />
                </StackPanel>

                <StackPanel x:Name="PanelExit" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="ソフト終了" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="Kakikomi を終了します。クリーン出力ウィンドウもあわせて閉じます。" />
                    <Button
                        x:Name="ExitAppBtn"
                        MinWidth="180"
                        MinHeight="44"
                        Content="アプリを終了" />
                </StackPanel>

                <StackPanel x:Name="PanelPalette" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="パレットの色編集" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="ペンを選ぶと混色パレットとスペクトルで色を選べます。RGB 数値入力も使えます。" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Name="Pen1SwatchBtn"
                            MinWidth="120"
                            MinHeight="48"
                            Padding="12,8"
                            Click="OnPen1SwatchClick">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse x:Name="SwatchRed" Width="28" Height="28" />
                                <TextBlock VerticalAlignment="Center" Text="ペン1" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="Pen2SwatchBtn"
                            MinWidth="120"
                            MinHeight="48"
                            Padding="12,8"
                            Click="OnPen2SwatchClick">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse x:Name="SwatchGreen" Width="28" Height="28" />
                                <TextBlock VerticalAlignment="Center" Text="ペン2" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="Pen3SwatchBtn"
                            MinWidth="120"
                            MinHeight="48"
                            Padding="12,8"
                            Click="OnPen3SwatchClick">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse x:Name="SwatchBlue" Width="28" Height="28" />
                                <TextBlock VerticalAlignment="Center" Text="ペン3" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="ResetPenColorsBtn"
                            MinWidth="160"
                            MinHeight="48"
                            Padding="12,8"
                            Content="デフォルトに戻す"
                            Click="OnResetPenColorsClick" />
                    </StackPanel>

                    <Border
                        x:Name="ColorEditorPanel"
                        Padding="12"
                        Background="#FF0F172A"
                        BorderBrush="#FF334155"
                        BorderThickness="1"
                        Visibility="Collapsed">
                        <StackPanel Spacing="10">
                            <Grid>
                                <TextBlock
                                    x:Name="ColorEditorTitle"
                                    FontWeight="SemiBold"
                                    Foreground="#FFE2E8F0"
                                    Text="ペン1 の色"
                                    VerticalAlignment="Center" />
                                <Button
                                    x:Name="CloseColorEditorBtn"
                                    MinWidth="72"
                                    MinHeight="32"
                                    Padding="10,4"
                                    HorizontalAlignment="Right"
                                    Content="閉じる"
                                    Click="OnCloseColorEditorClick" />
                            </Grid>

                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel
                                    Grid.Column="0"
                                    Spacing="6"
                                    VerticalAlignment="Top">
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Width="14"
                                            VerticalAlignment="Center"
                                            Foreground="#FF94A3B8"
                                            Text="R" />
                                        <NumberBox
                                            x:Name="RgbRBox"
                                            Grid.Column="1"
                                            Width="52"
                                            MinWidth="52"
                                            MinHeight="28"
                                            Padding="6,2"
                                            Minimum="0"
                                            Maximum="255"
                                            SpinButtonPlacementMode="Hidden" />
                                    </Grid>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Width="14"
                                            VerticalAlignment="Center"
                                            Foreground="#FF94A3B8"
                                            Text="G" />
                                        <NumberBox
                                            x:Name="RgbGBox"
                                            Grid.Column="1"
                                            Width="52"
                                            MinWidth="52"
                                            MinHeight="28"
                                            Padding="6,2"
                                            Minimum="0"
                                            Maximum="255"
                                            SpinButtonPlacementMode="Hidden" />
                                    </Grid>
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Width="14"
                                            VerticalAlignment="Center"
                                            Foreground="#FF94A3B8"
                                            Text="B" />
                                        <NumberBox
                                            x:Name="RgbBBox"
                                            Grid.Column="1"
                                            Width="52"
                                            MinWidth="52"
                                            MinHeight="28"
                                            Padding="6,2"
                                            Minimum="0"
                                            Maximum="255"
                                            SpinButtonPlacementMode="Hidden" />
                                    </Grid>
                                </StackPanel>

                                <controls:MixColorPalette
                                    x:Name="ActiveColorPalette"
                                    Grid.Column="1"
                                    VerticalAlignment="Top"
                                    MaxWidth="190" />

                                <ColorPicker
                                    x:Name="ActiveColorPicker"
                                    Grid.Column="2"
                                    VerticalAlignment="Top"
                                    CornerRadius="0"
                                    ColorSpectrumShape="Box"
                                    IsColorChannelTextInputVisible="False"
                                    IsHexInputVisible="False"
                                    IsAlphaEnabled="False"
                                    IsAlphaSliderVisible="False"
                                    IsAlphaTextInputVisible="False"
                                    MaxWidth="240"
                                    MaxHeight="220" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="PanelPenSize" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="ペンサイズ" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="描画ペンと消しゴムの太さを変更します。操作画面にも現在の太さが表示されます。" />
                    <NumberBox
                        x:Name="PenSizeBox"
                        Header="ペン太さ"
                        Minimum="1"
                        Maximum="40"
                        SmallChange="1"
                        LargeChange="2"
                        SpinButtonPlacementMode="Inline" />
                    <NumberBox
                        x:Name="EraserSizeBox"
                        Header="消しゴム太さ"
                        Minimum="4"
                        Maximum="80"
                        SmallChange="1"
                        LargeChange="4"
                        SpinButtonPlacementMode="Inline" />
                </StackPanel>

                <StackPanel x:Name="PanelFullSize" Spacing="16" Visibility="Collapsed">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FFF8FAFC" Text="コンパネ起動サイズ" />
                    <TextBlock
                        Foreground="#FF94A3B8"
                        TextWrapping="Wrap"
                        Text="次回起動時の最大化と、いますぐフルスクリーンにする操作を分けています。" />
                    <CheckBox
                        x:Name="FullSizeNextLaunchCheck"
                        Content="次回起動時にフルサイズ（最大化）で開く"
                        Foreground="#FFE2E8F0" />
                    <Button
                        x:Name="FullScreenNowBtn"
                        MinWidth="220"
                        MinHeight="44"
                        Content="いまフルスクリーンにする" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
