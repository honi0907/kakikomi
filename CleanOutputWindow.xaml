<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Kakikomi.CleanOutputWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kakikomi.Controls"
    Title="Kakikomi Clean">

    <Grid Background="Black">
        <Viewbox Stretch="Uniform">
            <Grid
                Width="1920"
                Height="1080"
                Background="Black">
                <MediaPlayerElement
                    x:Name="PlayerElement"
                    AreTransportControlsEnabled="False"
                    AutoPlay="False"
                    Stretch="Uniform" />
                <controls:DesignInkCanvas x:Name="InkLayer" IsHitTestVisible="False" />
                <controls:DemoWatermarkOverlay
                    x:Name="DemoWatermark"
                    Width="1920"
                    Height="1080"
                    Visibility="Collapsed" />
            </Grid>
        </Viewbox>
    </Grid>
</Window>
