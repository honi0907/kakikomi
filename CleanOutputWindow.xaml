<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Kakikomi.CleanOutputWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kakikomi.Controls"
    Title="Kakikomi Clean">

    <Grid Background="Black">
        <Viewbox Stretch="Uniform">
            <Grid
                Width="1920"
                Height="1080"
                Background="Black">
                <MediaPlayerElement
                    x:Name="PlayerElement"
                    AreTransportControlsEnabled="False"
                    AutoPlay="False"
                    Stretch="Uniform" />
                <controls:DesignInkCanvas x:Name="InkLayer" IsHitTestVisible="False" />
                <TextBlock
                    x:Name="DemoWatermark"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="220"
                    FontWeight="Bold"
                    Foreground="#66EF4444"
                    IsHitTestVisible="False"
                    Opacity="0.4"
                    RenderTransformOrigin="0.5,0.5"
                    Text="DEMO"
                    Visibility="Collapsed">
                    <TextBlock.RenderTransform>
                        <RotateTransform Angle="-28" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>
        </Viewbox>
    </Grid>
</Window>
