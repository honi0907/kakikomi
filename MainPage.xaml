<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Kakikomi.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Kakikomi.Controls"
    xmlns:models="using:Kakikomi.Models">

    <Grid
        Padding="12"
        Background="{StaticResource OpPageBg}"
        ColumnSpacing="12"
        RowSpacing="8"
        RequestedTheme="Dark">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 更新ありバナー -->
        <Border
            x:Name="UpdateBanner"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,8"
            Padding="12,10"
            Background="#FF1E3A5F"
            BorderBrush="#FF38BDF8"
            BorderThickness="1"
            CornerRadius="0"
            Visibility="{x:Bind ViewModel.UpdateBannerVisibility, Mode=OneWay}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{StaticResource OpTextBrush}"
                    Text="{x:Bind ViewModel.UpdateBannerMessage, Mode=OneWay}" />
                <Button
                    Grid.Column="1"
                    Style="{StaticResource OpButtonStyle}"
                    MinWidth="88"
                    MinHeight="36"
                    Padding="12,6"
                    FontSize="13"
                    Command="{x:Bind ViewModel.ApplyOnlineUpdateCommand}"
                    Content="更新" />
                <Button
                    Grid.Column="2"
                    Style="{StaticResource OpButtonStyle}"
                    MinWidth="72"
                    MinHeight="36"
                    Padding="12,6"
                    FontSize="13"
                    Command="{x:Bind ViewModel.DismissUpdateBannerCommand}"
                    Content="閉じる" />
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Grid.RowSpan="3"
            Grid.Column="0"
            Padding="10"
            Background="{StaticResource OpBarBg}"
            BorderBrush="{StaticResource OpPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="0">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="8">
                    <TextBlock
                        Foreground="{StaticResource OpTextBrush}"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="ネタ一覧" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="PickFolderBtn"
                            Style="{StaticResource OpButtonStyle}"
                            Command="{x:Bind ViewModel.PickFolderCommand}"
                            Content="フォルダ選択"
                            IsEnabled="{x:Bind ViewModel.IsEditMode, Mode=OneWay}" />
                        <Button
                            x:Name="RefreshBtn"
                            Style="{StaticResource OpButtonStyle}"
                            Command="{x:Bind ViewModel.RefreshFolderCommand}"
                            Content="更新"
                            IsEnabled="{x:Bind ViewModel.IsEditMode, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>

                <ListView
                    x:Name="NetaList"
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.NetaItems, Mode=OneWay}"
                    ItemContainerStyle="{StaticResource NetaListItemContainerStyle}"
                    SelectedItem="{x:Bind ViewModel.SelectedNeta, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:NetaItem">
                            <Border
                                Padding="6"
                                Background="#FF1E293B"
                                BorderBrush="{StaticResource OpPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="0">
                                <Grid>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="84" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="84"
                                            Height="47"
                                            Background="#FF020617"
                                            BorderBrush="#FF334155"
                                            BorderThickness="1">
                                            <Grid>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#FF64748B"
                                                    Text="…" />
                                                <Image
                                                    Stretch="UniformToFill"
                                                    Source="{x:Bind Thumbnail, Mode=OneWay}" />
                                                <Border Visibility="{Binding ViewModel.EditModeVisibility, ElementName=RootPage}">
                                                    <Border
                                                        Margin="2"
                                                        Padding="3,1"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Background="#CC020617"
                                                        CornerRadius="0"
                                                        Visibility="{x:Bind ConvertStatusVisibility, Mode=OneWay}">
                                                        <TextBlock
                                                            FontSize="9"
                                                            FontWeight="SemiBold"
                                                            Foreground="{x:Bind ConvertStatusBrush, Mode=OneWay}"
                                                            Text="{x:Bind ConvertStatusLabel, Mode=OneWay}" />
                                                    </Border>
                                                </Border>
                                                <Border
                                                    Margin="2"
                                                    Padding="3,1"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Background="#CC020617"
                                                    CornerRadius="0"
                                                    Visibility="{x:Bind FrameRateVisibility, Mode=OneWay}">
                                                    <TextBlock
                                                        FontSize="9"
                                                        FontWeight="SemiBold"
                                                        Foreground="#FFE2E8F0"
                                                        Text="{x:Bind FrameRateLabel, Mode=OneWay}" />
                                                </Border>
                                                <Button
                                                    Width="18"
                                                    Height="18"
                                                    MinWidth="18"
                                                    MinHeight="18"
                                                    Margin="1"
                                                    Padding="0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Background="#CC020617"
                                                    BorderBrush="#FF64748B"
                                                    BorderThickness="1"
                                                    Content="×"
                                                    FontSize="10"
                                                    FontWeight="Bold"
                                                    Foreground="#FFF8FAFC"
                                                    ToolTipService.ToolTip="削除"
                                                    Command="{Binding ViewModel.DeleteNetaCommand, ElementName=RootPage}"
                                                    CommandParameter="{x:Bind}"
                                                    IsEnabled="{Binding ViewModel.IsEditMode, ElementName=RootPage}" />
                                            </Grid>
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{StaticResource OpTextBrush}"
                                            Text="{x:Bind DisplayName}"
                                            TextWrapping="WrapWholeWords"
                                            TextTrimming="CharacterEllipsis"
                                            MaxLines="3" />
                                    </Grid>
                                    <!-- 変換中: ネタ行全体を左→右で明るく戻す（右原点で暗い帯が縮む） -->
                                    <Border
                                        Background="#B3000000"
                                        IsHitTestVisible="False"
                                        Visibility="{x:Bind ConvertProgressVisibility, Mode=OneWay}"
                                        RenderTransformOrigin="1,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="{x:Bind ConvertDarkScaleX, Mode=OneWay}" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Spacing="8">
                    <TextBlock
                        FontSize="13"
                        Foreground="{StaticResource OpMutedTextBrush}"
                        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Grid.RowSpan="2"
            Grid.Column="1"
            RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="Black"
                CornerRadius="0">
                <Viewbox Stretch="Uniform">
                    <Grid Width="1920" Height="1080" Background="Black">
                        <MediaPlayerElement
                            x:Name="OperatorPlayerA"
                            AreTransportControlsEnabled="False"
                            AutoPlay="False"
                            Stretch="Uniform" />
                        <MediaPlayerElement
                            x:Name="OperatorPlayerB"
                            AreTransportControlsEnabled="False"
                            AutoPlay="False"
                            Stretch="Uniform" />
                        <controls:DesignInkCanvas x:Name="InkLayer" />
                    </Grid>
                </Viewbox>
            </Border>

            <Border
                Grid.Row="1"
                Padding="8,8"
                Background="#FF020617"
                BorderBrush="{StaticResource OpPanelBorderBrush}"
                BorderThickness="1,1,1,0"
                CornerRadius="0">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        MinWidth="132"
                        VerticalAlignment="Center"
                        FontFamily="Consolas"
                        FontSize="15"
                        Foreground="{StaticResource OpTextBrush}"
                        Text="{x:Bind ViewModel.TimelineText, Mode=OneWay}" />
                    <controls:TimelineSeekBar
                        x:Name="TimelineSeek"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsEnabled="{x:Bind ViewModel.HasTimeline, Mode=OneWay}"
                        SeekStarted="OnTimelineSeekStarted"
                        SeekPreview="OnTimelineSeekPreview"
                        SeekCompleted="OnTimelineSeekCompleted" />
                </Grid>
            </Border>
        </Grid>

        <Border
            Grid.Row="3"
            Grid.Column="1"
            Padding="10"
            Background="{StaticResource OpBarBg}"
            BorderBrush="{StaticResource OpPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ScrollViewer
                    Grid.Column="0"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        x:Name="PlayToggle"
                        Style="{StaticResource OpButtonStyle}"
                        MinWidth="120"
                        Command="{x:Bind ViewModel.PlayPauseCommand}"
                        Content="再生/停止" />

                    <Button
                        x:Name="SkipBackBtn"
                        Style="{StaticResource OpButtonStyle}"
                        Command="{x:Bind ViewModel.SkipBackCommand}"
                        Content="-5秒" />
                    <Button
                        x:Name="SkipForwardBtn"
                        Style="{StaticResource OpButtonStyle}"
                        Command="{x:Bind ViewModel.SkipForwardCommand}"
                        Content="+5秒" />

                    <Border Width="3" Margin="10,6" Background="#FF475569" />

                    <ToggleButton
                        x:Name="RateNormalBtn"
                        Style="{StaticResource OpToggleStyle}"
                        Command="{x:Bind ViewModel.RateNormalCommand}"
                        Content="等速"
                        IsChecked="{x:Bind ViewModel.IsRateNormal, Mode=OneWay}" />
                    <ToggleButton
                        x:Name="RateHalfBtn"
                        Style="{StaticResource OpToggleStyle}"
                        Command="{x:Bind ViewModel.RateHalfCommand}"
                        Content="0.5x"
                        IsChecked="{x:Bind ViewModel.IsRateHalf, Mode=OneWay}" />
                    <ToggleButton
                        x:Name="RateQuarterBtn"
                        Style="{StaticResource OpToggleStyle}"
                        Command="{x:Bind ViewModel.RateQuarterCommand}"
                        Content="0.25x"
                        IsChecked="{x:Bind ViewModel.IsRateQuarter, Mode=OneWay}" />
                    <ToggleButton
                        x:Name="RateDoubleBtn"
                        Style="{StaticResource OpToggleStyle}"
                        Command="{x:Bind ViewModel.RateDoubleCommand}"
                        Content="2x"
                        IsChecked="{x:Bind ViewModel.IsRateDouble, Mode=OneWay}" />

                    <Border Width="3" Margin="10,6" Background="#FF475569" />

                    <ToggleButton
                        x:Name="PenRedBtn"
                        Style="{StaticResource OpPenSwatchToggleStyle}"
                        Command="{x:Bind ViewModel.SelectPenRedCommand}"
                        IsChecked="{x:Bind ViewModel.IsPenRed, Mode=OneWay}"
                        ToolTipService.ToolTip="赤ペン">
                        <Ellipse x:Name="PenRedSwatch" Width="26" Height="26" Fill="#FFEF4444" IsHitTestVisible="False" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="PenGreenBtn"
                        Style="{StaticResource OpPenSwatchToggleStyle}"
                        Command="{x:Bind ViewModel.SelectPenGreenCommand}"
                        IsChecked="{x:Bind ViewModel.IsPenGreen, Mode=OneWay}"
                        ToolTipService.ToolTip="緑ペン">
                        <Ellipse x:Name="PenGreenSwatch" Width="26" Height="26" Fill="#FF22C55E" IsHitTestVisible="False" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="PenBlueBtn"
                        Style="{StaticResource OpPenSwatchToggleStyle}"
                        Command="{x:Bind ViewModel.SelectPenBlueCommand}"
                        IsChecked="{x:Bind ViewModel.IsPenBlue, Mode=OneWay}"
                        ToolTipService.ToolTip="青ペン">
                        <Ellipse x:Name="PenBlueSwatch" Width="26" Height="26" Fill="#FF3B82F6" IsHitTestVisible="False" />
                    </ToggleButton>
                    <ToggleButton
                        x:Name="PenEraserBtn"
                        Style="{StaticResource OpToggleStyle}"
                        Width="48"
                        Height="48"
                        MinWidth="48"
                        MinHeight="48"
                        Padding="0"
                        Command="{x:Bind ViewModel.SelectPenEraserCommand}"
                        IsChecked="{x:Bind ViewModel.IsPenEraser, Mode=OneWay}"
                        ToolTipService.ToolTip="消しゴム">
                        <!-- 添付イメージと同じ：青スリーブ＋白先端のブロック消しゴム -->
                        <Viewbox Width="30" Height="30" IsHitTestVisible="False">
                            <Grid Width="24" Height="24">
                                <Border
                                    Width="18"
                                    Height="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    BorderBrush="#FF42A5F5"
                                    BorderThickness="2.2"
                                    CornerRadius="2.2"
                                    RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <RotateTransform Angle="-45" />
                                    </Border.RenderTransform>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.32*" />
                                            <ColumnDefinition Width="0.68*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Fill="#FFFFFFFF" />
                                        <Rectangle Grid.Column="1" Fill="#FF42A5F5" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Viewbox>
                    </ToggleButton>
                    <Border
                        Margin="4,0,0,0"
                        Padding="2"
                        VerticalAlignment="Center"
                        Background="#FF1E293B"
                        BorderBrush="#FF475569"
                        BorderThickness="1"
                        ToolTipService.ToolTip="ペン／消しゴムの太さ（現在のツール）">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button
                                x:Name="PenThicknessMinusBtn"
                                Width="28"
                                Height="32"
                                MinWidth="28"
                                MinHeight="32"
                                Padding="0"
                                Style="{StaticResource OpButtonStyle}"
                                Content="−"
                                FontSize="14"
                                Command="{x:Bind ViewModel.DecreasePenThicknessCommand}" />
                            <TextBlock
                                MinWidth="44"
                                Margin="2,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                FontFamily="Consolas"
                                FontSize="13"
                                Foreground="{StaticResource OpTextBrush}"
                                Text="{x:Bind ViewModel.PenThicknessLabel, Mode=OneWay}"
                                TextAlignment="Center" />
                            <Button
                                x:Name="PenThicknessPlusBtn"
                                Width="28"
                                Height="32"
                                MinWidth="28"
                                MinHeight="32"
                                Padding="0"
                                Style="{StaticResource OpButtonStyle}"
                                Content="＋"
                                FontSize="14"
                                Command="{x:Bind ViewModel.IncreasePenThicknessCommand}" />
                        </StackPanel>
                    </Border>

                    <Button
                        x:Name="ClearInkBtn"
                        Style="{StaticResource OpButtonStyle}"
                        MinWidth="140"
                        Command="{x:Bind ViewModel.ClearInkCommand}"
                        Content="全消去" />
                    </StackPanel>
                </ScrollViewer>
                <StackPanel
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <Button
                        x:Name="EditModeBtn"
                        Style="{StaticResource OpButtonStyle}"
                        MinWidth="88"
                        MinHeight="36"
                        Padding="12,6"
                        FontSize="13"
                        Command="{x:Bind ViewModel.ToggleEditModeCommand}"
                        Content="編集モード" />
                    <Button
                        x:Name="SettingsBtn"
                        Style="{StaticResource OpButtonStyle}"
                        MinWidth="72"
                        MinHeight="36"
                        Padding="12,6"
                        FontSize="13"
                        IsEnabled="{x:Bind ViewModel.IsEditMode, Mode=OneWay}"
                        Command="{x:Bind ViewModel.OpenSettingsCommand}"
                        Content="設定" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- DEMO ウォーターマーク（画面全体に敷き詰め） -->
        <controls:DemoWatermarkOverlay
            x:Name="DemoWatermark"
            Grid.RowSpan="4"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Visibility="Collapsed" />
    </Grid>
</Page>
